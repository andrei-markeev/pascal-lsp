<ProgramFile><RW>program</RW> <SymbDecl>GoodCase</SymbDecl><RW>;</RW>

<VarSection><RW>var</RW>
    <VarDecl><SymbDecl>x</SymbDecl><RW>:</RW> <TypeSpec><Ident>integer</Ident></TypeSpec></VarDecl><RW>;</RW>
    <VarDecl><SymbDecl>ch</SymbDecl><RW>:</RW> <TypeSpec><Ident>char</Ident></TypeSpec></VarDecl><RW>;</RW>
    <VarDecl><SymbDecl>kind</SymbDecl><RW>:</RW> <TypeSpec><EnumSpec><RW>(</RW><SymbDecl>red</SymbDecl><RW>,</RW> <SymbDecl>green</SymbDecl><RW>,</RW> <SymbDecl>blue</SymbDecl><RW>)</RW></EnumSpec></TypeSpec></VarDecl><RW>;</RW></VarSection>
<Block><RW>begin</RW>
    <Case><RW>case</RW> <SymbRef>x</SymbRef> <RW>of</RW>
        <CaseBranch><Num>1</Num><RW>:</RW> <Assignment><SymbRef>x</SymbRef> <RW>:=</RW> <Num>10</Num></Assignment></CaseBranch><RW>;</RW>
        <CaseBranch><Num>2</Num><RW>,</RW> <Num>3</Num><RW>:</RW> <Assignment><SymbRef>x</SymbRef> <RW>:=</RW> <Num>20</Num></Assignment></CaseBranch><RW>;</RW>
        <CaseBranch><Num>4</Num><RW>..</RW><Num>10</Num><RW>:</RW> <Assignment><SymbRef>x</SymbRef> <RW>:=</RW> <Num>30</Num></Assignment></CaseBranch><RW>;</RW>
        <RW>else</RW> <Assignment><SymbRef>x</SymbRef> <RW>:=</RW> <Num>0</Num></Assignment><RW>;</RW>
    <RW>end</RW></Case><RW>;</RW>

    <Case><RW>case</RW> <SymbRef>ch</SymbRef> <RW>of</RW>
