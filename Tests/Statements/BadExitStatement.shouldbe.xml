<Procedure><RW>procedure</RW> <SymbDecl>TestTpError</SymbDecl><RW>;</RW>
{$mode tp}
<Block><RW>begin</RW>
    <Call><SymbRef>Exit</SymbRef><RW>(</RW><Num>123</Num><RW>)</RW></Call><RW>;</RW>
<RW>end</RW></Block><RW>;</RW></Procedure>

<Procedure><RW>procedure</RW> <SymbDecl>TestMacPasError</SymbDecl><RW>;</RW>
{$mode macpas}
<Block><RW>begin</RW>
    <Call><SymbRef>Exit</SymbRef></Call><RW>;</RW>
<RW>end</RW></Block><RW>;</RW></Procedure>

<Procedure><RW>procedure</RW> <SymbDecl>TestTooManyArgs</SymbDecl><RW>;</RW>
